. /* ==========================================================================
>    ETAPE 1 : PREPARATION DE LA BASE DE DONNEES
>    ========================================================================== */
. import excel "BDD.xlsx", sheet("Data") firstrow clear
(69 vars, 214 obs)

. 
. rename SeriesCode code

. rename CountryName pays

. rename CountryCode id_pays 

. drop SeriesName

. 
. 
. keep if inlist(code, "NE.GDI.TOTL.ZS", "NY.GNS.ICTR.ZS", "NY.GDP.MKTP.KD.ZG", "NE.TRD.GNFS.ZS")
(94 observations deleted)

. 
. drop if missing(pays)
(0 observations deleted)

. duplicates drop pays code, force

Duplicates in terms of pays code

(0 observations are duplicates)

. 
. // Reshape Long (Années)
. reshape long YR, i(pays id_pays code) j(annee)
(j = 1960 1961 1962 1963 1964 1965 1966 1967 1968 1969 1970 1971 1972 1973 1974 1975 1976 1977 1978 1979 1980 1981 1982 1983 1984 1985 1986 1987 1988 1989 1990 1991 199
> 2 1993 1994 1995 1996 1997 1998 1999 2000 2001 2002 2003 2004 2005 2006 2007 2008 2009 2010 2011 2012 2013 2014 2015 2016 2017 2018 2019 2020 2021 2022 2023 2024)

Data                               Wide   ->   Long
-----------------------------------------------------------------------------
Number of observations              120   ->   7,800       
Number of variables                  68   ->   5           
j variable (65 values)                    ->   annee
xij variables:
               YR1960 YR1961 ... YR2024   ->   YR
-----------------------------------------------------------------------------

. replace YR = "" if YR == ".."
(1,374 real changes made)

. destring YR, replace force
YR: all characters numeric; replaced as double
(1374 missing values generated)

. rename YR valeur

. 
. // Reshape Wide (Variables)
. replace code = "Investissement" if code == "NE.GDI.TOTL.ZS"
(1,950 real changes made)

. replace code = "Epargne" if code == "NY.GNS.ICTR.ZS"
(1,950 real changes made)

. replace code = "Croissance" if code == "NY.GDP.MKTP.KD.ZG"
(1,950 real changes made)

. replace code = "Ouverture" if code == "NE.TRD.GNFS.ZS"
(1,950 real changes made)

. 
. reshape wide valeur, i(pays id_pays annee) j(code) string
(j = Croissance Epargne Investissement Ouverture)

Data                               Long   ->   Wide
-----------------------------------------------------------------------------
Number of observations            7,800   ->   1,950       
Number of variables                   5   ->   7           
j variable (4 values)              code   ->   (dropped)
xij variables:
                                 valeur   ->   valeurCroissance valeurEpargne ... valeurOuverture
-----------------------------------------------------------------------------

. rename valeur* *

. 
. // Labeling
